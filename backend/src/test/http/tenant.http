### 관리자 회원가입 성공
POST http://localhost:10000/api/v1/auth/signup
Content-Type: application/json
X-Tenant-Code: alpha

{
  "email": "admin@example.com",
  "password": "admin1234!",
  "nickname": "어드민1",
  "phone": "01012345678"
}

### 관리자 로그인 성공
POST http://localhost:10000/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "admin1234!"
}

> {%
  client.global.set("adminAccessToken", response.body.data.accessToken);
  client.global.set("adminRefreshToken", response.body.data.refreshToken);
%}


### 고객사 회원가입 성공
POST http://localhost:10000/api/v1/auth/signup
Content-Type: application/json
X-Tenant-Code: alpha

{
  "email": "testuser1@example.com",
  "password": "Test1234!",
  "nickname": "테스트유저1",
  "phone": "01012345678"
}

### 고객사 로그인 성공
POST http://localhost:10000/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "testuser1@example.com",
  "password": "Test1234!"
}

> {%
  client.global.set("accessToken", response.body.data.accessToken);
  client.global.set("refreshToken", response.body.data.refreshToken);
%}

### tenant 생성
POST http://localhost:10000/api/v1/admin/tenants
Content-Type: application/json
Authorization: Bearer {{adminAccessToken}}

{
  "code": "alpha",
  "name": "Alpha Company"
}

### tenant 초대 생성
POST http://localhost:10000/api/v1/tenant-invitations
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Code: alpha

{
  "email": "member1@example.com",
  "role": "VIEWER"
}


> {%
  client.global.set("inviteToken", response.body.data.token);
%}

### tenant 초대 수락
POST http://localhost:10000/api/v1/tenant-invitations/accept
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "token": "{{inviteToken}}"
}

### 초대 기반 회원가입
POST http://localhost:10000/api/v1/auth/signup/invitation
Content-Type: application/json

{
  "inviteToken": "{{inviteToken}}",
  "email": "member1@example.com",
  "password": "Test1234!",
  "nickname": "멤버1",
  "phone": "01012345678"
}

### 로그인된 기존 사용자 초대 수락
POST http://localhost:10000/api/v1/tenant-invitations/accept
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "token": "{{inviteToken}}"
}

### 내 테넌트 목록 조회
GET http://localhost:10000/api/v1/tenants/my
Authorization: Bearer {{accessToken}}

### 내 기본 테넌트 조회
GET http://localhost:10000/api/v1/tenants/my/primary
Authorization: Bearer {{accessToken}}

### 기본 테넌트 변경
PATCH http://localhost:10000/api/v1/tenants/my/primary
Content-Type: application/json
Authorization: Bearer {{accessToken}}